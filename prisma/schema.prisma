generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// CRM admin auth (Auth.js)
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  AGENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  role          UserRole  @default(AGENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  documents Document[] @relation("DocumentUploadedByUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Consumer accounts (marketing site)
// ---------------------------------------------------------------------------

model Customer {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings     Listing[]
  sellInquiries SellInquiry[]
}

// ---------------------------------------------------------------------------
// Seller contacts & portal sessions
// ---------------------------------------------------------------------------

enum ContactRole {
  PRIMARY
  CO_SELLER
}

model Contact {
  id               String   @id @default(cuid())
  airtableRecordId String?  @unique
  name             String
  email            String   @unique
  phone            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  listings       ListingContact[]
  portalSessions PortalSession[]
  sellerRequests SellerRequest[]
  documents      Document[]       @relation("DocumentUploadedByContact")
}

model PortalSession {
  id        String   @id @default(cuid())
  token     String   @unique
  contactId String
  listingId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([contactId])
}

model ListingContact {
  id        String      @id @default(cuid())
  listingId String
  contactId String
  role      ContactRole @default(PRIMARY)
  createdAt DateTime    @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listingId, contactId])
  @@index([contactId])
}

// ---------------------------------------------------------------------------
// Closing team
// ---------------------------------------------------------------------------

enum ClosingTeamRole {
  ESCROW_OFFICER
  TRANSACTION_COORDINATOR
}

model ClosingTeamMember {
  id               String          @id @default(cuid())
  airtableRecordId String?         @unique
  name             String
  role             ClosingTeamRole
  type             String?
  company          String?
  phone            String?
  email            String?
  website          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  listingsAsEscrowOfficer Listing[] @relation("ListingEscrowOfficer")
  listingsAsTC            Listing[] @relation("ListingTC")
}

// ---------------------------------------------------------------------------
// Listings
// ---------------------------------------------------------------------------

enum ListingStatus {
  SUBMITTED
  ACTIVE
  UNDER_CONTRACT
  PENDING
  CLOSED
  CANCELLED
}

model Listing {
  id               String        @id @default(cuid())
  airtableRecordId String?       @unique
  address          String
  city             String
  state            String
  zip              String
  listPrice        Decimal?      @db.Decimal(12, 2)
  beds             String?
  baths            String?
  sqft             String?
  mlsNumber        String?
  listDate         DateTime?     @db.Date
  status           ListingStatus @default(ACTIVE)

  portalSlug   String @unique
  passcodeHash String
  offerFormUrl String?

  blairNote           String?   @db.Text
  blairNoteDate       DateTime? @db.Date
  latestViews         Int?
  latestSaves         Int?
  latestShowings      Int?
  priceReductionDate  DateTime? @db.Date
  priceReductionCount Int       @default(0)
  activeOffers        Int       @default(0)
  marketAvgDom        Int?
  portfolioGroup      String?

  latitude       Float?
  longitude      Float?
  yearBuilt      Int?
  lotSizeAcres   Decimal? @db.Decimal(10, 4)
  neighborhood   String?
  subdivision    String?
  hasPool        Boolean?
  listingOffice  String?
  virtualTourUrl String?
  description    String?  @db.Text

  escrowOfficerId          String?
  transactionCoordinatorId String?
  customerId               String?
  submittedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer               Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  escrowOfficer          ClosingTeamMember? @relation("ListingEscrowOfficer", fields: [escrowOfficerId], references: [id], onDelete: SetNull)
  transactionCoordinator ClosingTeamMember? @relation("ListingTC", fields: [transactionCoordinatorId], references: [id], onDelete: SetNull)

  contacts       ListingContact[]
  portalSessions PortalSession[]
  showings       Showing[]
  weeklyStats    WeeklyStat[]
  offers         Offer[]
  documents      Document[]
  sellerRequests SellerRequest[]
  sellInquiries  SellInquiry[]

  @@index([city])
  @@index([portfolioGroup])
  @@index([status])
  @@index([listPrice])
  @@index([latitude, longitude])
  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Showings
// ---------------------------------------------------------------------------

model Showing {
  id               String    @id @default(cuid())
  airtableRecordId String?   @unique
  listingId        String
  showingDate      DateTime  @db.Date
  showingTime      String?
  showingLabel     String?
  buyersAgent      String?
  feedback         String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, showingDate])
}

// ---------------------------------------------------------------------------
// Weekly traffic stats (Listtrac)
// ---------------------------------------------------------------------------

model WeeklyStat {
  id               String   @id @default(cuid())
  airtableRecordId String?  @unique
  listingId        String
  weekEnding       DateTime @db.Date

  listtracTotal30d    Int?
  ureViews30d         Int?
  zillowViews30d      Int?
  realtorViews30d     Int?
  homesViews30d       Int?
  truliaViews30d      Int?
  ureFavoritesCumulative Int?
  lifetimeViews       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, weekEnding])
  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Offers
// ---------------------------------------------------------------------------

enum OfferStatus {
  PENDING_REVIEW
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

model Offer {
  id               String      @id @default(cuid())
  airtableRecordId String?     @unique
  listingId        String
  submittedDate    DateTime    @default(now())
  offerPrice       Decimal?    @db.Decimal(12, 2)
  buyersAgent      String?
  financingType    String?
  status           OfferStatus @default(PENDING_REVIEW)

  // Contract fields (filled when accepted / under contract)
  contractPrice              Decimal?  @db.Decimal(12, 2)
  settlementDate             DateTime? @db.Date
  sellerConcessions            String?
  buyerDueDiligenceDeadline  DateTime? @db.Date
  homeWarranty               String?
  financingAppraisalDeadline DateTime? @db.Date
  sellerDisclosureDeadline   DateTime? @db.Date

  // Extended JotForm replacement fields
  buyerName          String?
  buyerEmail         String?
  buyerPhone         String?
  buyerAgentEmail    String?
  buyerAgentPhone    String?
  earnestMoney       Decimal?  @db.Decimal(12, 2)
  closingDate        DateTime? @db.Date
  inspectionPeriod   String?
  appraisalGap       String?
  contingencies      String?   @db.Text
  additionalTerms    String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing   Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  documents OfferDocument[]

  @@index([listingId, submittedDate])
  @@index([status])
}

model OfferDocument {
  id         String   @id @default(cuid())
  offerId    String
  name       String
  url        String
  uploadedAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
}

// ---------------------------------------------------------------------------
// Market data (city-level, Boldtrail)
// ---------------------------------------------------------------------------

model MarketData {
  id               String   @id @default(cuid())
  airtableRecordId String?  @unique
  city             String
  reportDate       DateTime @db.Date

  homesForSale            Int?
  homesForSaleChangePct   Decimal? @db.Decimal(8, 4)
  newToMarket             Int?
  newToMarketChangePct    Decimal? @db.Decimal(8, 4)
  homesSoldCount          Int?
  homesSoldChangePct      Decimal? @db.Decimal(8, 4)
  avgDom                  Int?
  domChangePct            Decimal? @db.Decimal(8, 4)
  avgHomePrice            Decimal? @db.Decimal(14, 2)
  avgHomePriceChangePct   Decimal? @db.Decimal(8, 4)
  avgSoldPrice            Decimal? @db.Decimal(14, 2)
  avgSoldPriceChangePct   Decimal? @db.Decimal(8, 4)
  pricePerSqFt            Decimal? @db.Decimal(10, 2)
  pricePerSqFtChangePct   Decimal? @db.Decimal(8, 4)
  priceReductionsCount    Int?
  priceReductionsChangePct Decimal? @db.Decimal(8, 4)
  soldToListedRatio       Decimal? @db.Decimal(8, 4)
  soldToListedChangePct   Decimal? @db.Decimal(8, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([city, reportDate])
  @@index([city])
}

// ---------------------------------------------------------------------------
// Sell inquiries (marketing site lead capture)
// ---------------------------------------------------------------------------

enum SellInquiryStatus {
  NEW
  LISTING_STARTED
  LISTING_SUBMITTED
}

model SellInquiry {
  id            String            @id @default(cuid())
  customerId    String?
  firstName     String
  lastName      String
  email         String
  phone         String
  streetAddress String
  city          String
  state         String
  zip           String
  timeline      String
  status        SellInquiryStatus @default(NEW)
  listingId     String?
  submittedAt   DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([customerId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Seller requests (inline portal forms)
// ---------------------------------------------------------------------------

enum SellerRequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
}

model SellerRequest {
  id               String              @id @default(cuid())
  airtableRecordId String?             @unique
  listingId        String
  contactId        String?
  sellerName       String
  sellerEmail      String
  propertyAddress  String
  submittedAt      DateTime            @default(now())
  status           SellerRequestStatus @default(NEW)
  requestSummary   String?
  updateTypes      String[]
  message          String?             @db.Text
  openHouseDate    DateTime?           @db.Date
  openHouseTime    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Documents (listing files / photos)
// ---------------------------------------------------------------------------

model Document {
  id                  String   @id @default(cuid())
  listingId           String
  name                String
  url                 String
  uploadedAt          DateTime @default(now())
  uploadedByContactId String?
  uploadedByUserId    String?

  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  uploadedByContact Contact? @relation("DocumentUploadedByContact", fields: [uploadedByContactId], references: [id], onDelete: SetNull)
  uploadedByUser    User?    @relation("DocumentUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Email automation log (optional)
// ---------------------------------------------------------------------------

enum EmailLogStatus {
  SENT
  FAILED
  PENDING
}

model EmailLog {
  id        String         @id @default(cuid())
  trigger   String
  recipient String
  template  String?
  subject   String?
  status    EmailLogStatus @default(PENDING)
  error     String?        @db.Text
  sentAt    DateTime?
  createdAt DateTime       @default(now())

  @@index([trigger])
  @@index([status])
}
