generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// CRM admin auth (Auth.js)
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  AGENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  role          UserRole  @default(AGENT)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  documents        Document[] @relation("DocumentUploadedByUser")
  assignedListings Listing[]  @relation("ListingAssignedAgent")
  mlsOpsAsDefaultVa MlsOpsSettings[] @relation("MlsOpsDefaultVa")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Consumer accounts (marketing site)
// ---------------------------------------------------------------------------

model Customer {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings            Listing[]
  sellInquiries       SellInquiry[]
  agreementSignatures AgreementSignature[]
}

// ---------------------------------------------------------------------------
// Seller contacts
// ---------------------------------------------------------------------------

enum ContactRole {
  PRIMARY
  CO_SELLER
}

model Contact {
  id               String   @id @default(cuid())
  airtableRecordId String?  @unique
  name             String
  email            String   @unique
  phone            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  listings       ListingContact[]
  sellerRequests SellerRequest[]
  documents      Document[]       @relation("DocumentUploadedByContact")
}

model ListingContact {
  id        String      @id @default(cuid())
  listingId String
  contactId String
  role      ContactRole @default(PRIMARY)
  createdAt DateTime    @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listingId, contactId])
  @@index([contactId])
}

// ---------------------------------------------------------------------------
// Closing team
// ---------------------------------------------------------------------------

enum ClosingTeamRole {
  ESCROW_OFFICER
  TRANSACTION_COORDINATOR
}

model ClosingTeamMember {
  id               String          @id @default(cuid())
  airtableRecordId String?         @unique
  name             String
  role             ClosingTeamRole
  type             String?
  company          String?
  phone            String?
  email            String?
  website          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  listingsAsEscrowOfficer Listing[] @relation("ListingEscrowOfficer")
  listingsAsTC            Listing[] @relation("ListingTC")
}

// ---------------------------------------------------------------------------
// Listings
// ---------------------------------------------------------------------------

enum ListingStatus {
  SUBMITTED
  ACTIVE
  UNDER_CONTRACT
  PENDING
  CLOSED
  CANCELLED
}

enum IntakeStatus {
  DRAFT
  SUBMITTED
}

enum ServicePlan {
  VIRTUAL
  FULL_SERVICE
}

enum OnboardingStatus {
  PLAN_PENDING
  AGREEMENT_PENDING
  PHOTOS_PENDING
  CALL_PENDING
  MLS_INTAKE_PENDING
  ONBOARDING_COMPLETE
}

model Listing {
  id               String        @id @default(cuid())
  airtableRecordId String?       @unique
  address          String
  city             String
  state            String
  zip              String
  listPrice        Decimal?      @db.Decimal(12, 2)
  beds             String?
  baths            String?
  sqft             String?
  mlsNumber        String?
  listDate         DateTime?     @db.Date
  status           ListingStatus @default(ACTIVE)

  listingSlug  String @unique
  offerFormUrl String?

  blairNote           String?   @db.Text
  blairNoteDate       DateTime? @db.Date
  latestViews         Int?
  latestSaves         Int?
  latestShowings      Int?
  priceReductionDate  DateTime? @db.Date
  priceReductionCount Int       @default(0)
  activeOffers        Int       @default(0)
  marketAvgDom        Int?
  portfolioGroup      String?

  latitude       Float?
  longitude      Float?
  yearBuilt      Int?
  lotSizeAcres   Decimal? @db.Decimal(10, 4)
  neighborhood   String?
  subdivision    String?
  hasPool        Boolean?
  listingOffice  String?
  virtualTourUrl String?
  description    String?  @db.Text

  escrowOfficerId          String?
  transactionCoordinatorId String?
  customerId               String?
  assignedAgentId          String?
  submittedAt              DateTime?

  servicePlan             ServicePlan?
  onboardingStatus        OnboardingStatus @default(PLAN_PENDING)
  agreementSignedAt       DateTime?
  agreementSignatureUrl   String?
  proPhotoTourRequested   Boolean          @default(false)
  scheduledCallAt         DateTime?
  callNotes               String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer               Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  escrowOfficer          ClosingTeamMember? @relation("ListingEscrowOfficer", fields: [escrowOfficerId], references: [id], onDelete: SetNull)
  transactionCoordinator ClosingTeamMember? @relation("ListingTC", fields: [transactionCoordinatorId], references: [id], onDelete: SetNull)
  assignedAgent          User?              @relation("ListingAssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)

  contacts       ListingContact[]
  showings       Showing[]
  weeklyStats    WeeklyStat[]
  offers         Offer[]
  documents           Document[]
  sellerRequests      SellerRequest[]
  sellInquiries       SellInquiry[]
  listingIntake       ListingIntake?
  agreementSignature  AgreementSignature?

  @@index([city])
  @@index([portfolioGroup])
  @@index([status])
  @@index([listPrice])
  @@index([latitude, longitude])
  @@index([customerId])
  @@index([assignedAgentId])
  @@index([onboardingStatus])
  @@index([scheduledCallAt])
  @@unique([scheduledCallAt])
}

model ListingIntake {
  id           String       @id @default(cuid())
  listingId    String       @unique
  status       IntakeStatus @default(DRAFT)
  currentStep  Int          @default(1)
  data         Json         @default("{}")
  signatureUrl String?
  submittedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Showings
// ---------------------------------------------------------------------------

model Showing {
  id               String    @id @default(cuid())
  airtableRecordId String?   @unique
  listingId        String
  showingDate      DateTime  @db.Date
  showingTime      String?
  showingLabel     String?
  buyersAgent      String?
  feedback         String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, showingDate])
}

// ---------------------------------------------------------------------------
// Weekly traffic stats (Listtrac)
// ---------------------------------------------------------------------------

model WeeklyStat {
  id               String   @id @default(cuid())
  airtableRecordId String?  @unique
  listingId        String
  weekEnding       DateTime @db.Date

  listtracTotal30d    Int?
  ureViews30d         Int?
  zillowViews30d      Int?
  realtorViews30d     Int?
  homesViews30d       Int?
  truliaViews30d      Int?
  ureFavoritesCumulative Int?
  lifetimeViews       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, weekEnding])
  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Offers
// ---------------------------------------------------------------------------

enum OfferStatus {
  PENDING_REVIEW
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

model Offer {
  id               String      @id @default(cuid())
  airtableRecordId String?     @unique
  listingId        String
  submittedDate    DateTime    @default(now())
  offerPrice       Decimal?    @db.Decimal(12, 2)
  buyersAgent      String?
  financingType    String?
  status           OfferStatus @default(PENDING_REVIEW)

  // Contract fields (filled when accepted / under contract)
  contractPrice              Decimal?  @db.Decimal(12, 2)
  settlementDate             DateTime? @db.Date
  sellerConcessions            String?
  buyerDueDiligenceDeadline  DateTime? @db.Date
  homeWarranty               String?
  financingAppraisalDeadline DateTime? @db.Date
  sellerDisclosureDeadline   DateTime? @db.Date

  // Extended JotForm replacement fields
  buyerName          String?
  buyerEmail         String?
  buyerPhone         String?
  buyerAgentEmail    String?
  buyerAgentPhone    String?
  earnestMoney       Decimal?  @db.Decimal(12, 2)
  closingDate        DateTime? @db.Date
  inspectionPeriod   String?
  appraisalGap       String?
  contingencies      String?   @db.Text
  additionalTerms    String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing   Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  documents OfferDocument[]

  @@index([listingId, submittedDate])
  @@index([status])
}

model OfferDocument {
  id         String   @id @default(cuid())
  offerId    String
  name       String
  url        String
  uploadedAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
}

// ---------------------------------------------------------------------------
// Market data (city-level, Boldtrail)
// ---------------------------------------------------------------------------

model MarketData {
  id               String   @id @default(cuid())
  airtableRecordId String?  @unique
  city             String
  reportDate       DateTime @db.Date
  isManualOverride Boolean  @default(false)

  homesForSale             Int?
  homesForSaleChangePct    Decimal? @db.Decimal(8, 4)
  newToMarket              Int?
  newToMarketChangePct     Decimal? @db.Decimal(8, 4)
  homesSoldCount           Int?
  homesSoldChangePct       Decimal? @db.Decimal(8, 4)
  avgDom                   Int?
  domChangePct             Decimal? @db.Decimal(8, 4)
  avgHomePrice             Decimal? @db.Decimal(14, 2)
  avgHomePriceChangePct    Decimal? @db.Decimal(8, 4)
  avgSoldPrice             Decimal? @db.Decimal(14, 2)
  avgSoldPriceChangePct    Decimal? @db.Decimal(8, 4)
  pricePerSqFt             Decimal? @db.Decimal(10, 2)
  pricePerSqFtChangePct    Decimal? @db.Decimal(8, 4)
  priceReductionsCount     Int?
  priceReductionsChangePct Decimal? @db.Decimal(8, 4)
  soldToListedRatio        String?
  soldToListedChangePct    Decimal? @db.Decimal(8, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([city, reportDate])
  @@index([city])
}

// ---------------------------------------------------------------------------
// Sell inquiries (marketing site lead capture)
// ---------------------------------------------------------------------------

enum SellInquiryStatus {
  NEW
  LISTING_STARTED
  LISTING_SUBMITTED
}

model SellInquiry {
  id            String            @id @default(cuid())
  customerId    String?
  firstName     String
  lastName      String
  email         String
  phone         String
  streetAddress String
  city          String
  state         String
  zip           String
  timeline      String
  status        SellInquiryStatus @default(NEW)
  listingId     String?
  submittedAt   DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([customerId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Seller requests (inline portal forms)
// ---------------------------------------------------------------------------

enum SellerRequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
}

model SellerRequest {
  id               String              @id @default(cuid())
  airtableRecordId String?             @unique
  listingId        String
  contactId        String?
  sellerName       String
  sellerEmail      String
  propertyAddress  String
  submittedAt      DateTime            @default(now())
  status           SellerRequestStatus @default(NEW)
  requestSummary   String?
  updateTypes      String[]
  message          String?             @db.Text
  openHouseDate    DateTime?           @db.Date
  openHouseTime    String?
  currentPrice     Decimal?            @db.Decimal(12, 2)
  newPrice         Decimal?            @db.Decimal(12, 2)
  reductionOption  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Agreement PDF templates (admin-managed)
// ---------------------------------------------------------------------------

model AgreementTemplate {
  id            String   @id @default(cuid())
  slug          String
  version       String
  displayName   String
  revisionLabel String?
  blobPathname  String
  localFilename String?
  contentHash   String?
  byteSize      Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([slug, version])
  @@index([slug])
  @@index([isActive])
}

// ---------------------------------------------------------------------------
// Transactional email templates (admin-managed)
// ---------------------------------------------------------------------------

model EmailTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  description String?
  subject     String
  htmlBody    String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailBrandSettings {
  id               String   @id @default("default")
  primaryColor     String   @default("#1a3a5c")
  pageBackground   String   @default("#F1F5F9")
  cardBackground   String   @default("#ffffff")
  bodyTextColor    String   @default("#1E293B")
  mutedTextColor   String   @default("#64748B")
  linkColor        String   @default("#1a3a5c")
  accentBackground String   @default("#EFF6FF")
  buttonRadius     String   @default("10px")
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// MLS ops (VA handoff)
// ---------------------------------------------------------------------------

model MlsOpsSettings {
  id                   String   @id @default("default")
  defaultVaUserId      String?
  fallbackEmail        String?
  preferAssignedAgent  Boolean  @default(false)
  updatedAt            DateTime @updatedAt

  defaultVaUser User? @relation("MlsOpsDefaultVa", fields: [defaultVaUserId], references: [id], onDelete: SetNull)
}

// ---------------------------------------------------------------------------
// Listing agreement e-sign audit
// ---------------------------------------------------------------------------

enum SignatureMethod {
  DRAW
  TYPE
}

model AgreementSignature {
  id                String          @id @default(cuid())
  listingId         String          @unique
  customerId        String
  signerName        String
  signerEmail       String
  signatureMethod   SignatureMethod
  signatureImageUrl String
  signedDocumentUrl String?
  agreementVersion  String
  agreementHash     String
  formData          Json?
  esignConsentAt    DateTime
  signedAt          DateTime
  ipAddress         String?
  userAgent         String?         @db.Text

  listing  Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Documents (listing files / photos)
// ---------------------------------------------------------------------------

model Document {
  id                  String   @id @default(cuid())
  listingId           String
  name                String
  url                 String
  uploadedAt          DateTime @default(now())
  uploadedByContactId String?
  uploadedByUserId    String?

  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  uploadedByContact Contact? @relation("DocumentUploadedByContact", fields: [uploadedByContactId], references: [id], onDelete: SetNull)
  uploadedByUser    User?    @relation("DocumentUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([listingId])
}

// ---------------------------------------------------------------------------
// Email automation log (optional)
// ---------------------------------------------------------------------------

enum EmailLogStatus {
  SENT
  FAILED
  PENDING
}

model EmailLog {
  id        String         @id @default(cuid())
  trigger   String
  recipient String
  template  String?
  subject   String?
  status    EmailLogStatus @default(PENDING)
  error     String?        @db.Text
  sentAt    DateTime?
  createdAt DateTime       @default(now())

  @@index([trigger])
  @@index([status])
}
