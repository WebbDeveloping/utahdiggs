# Copy from Vercel dashboard after provisioning Prisma Postgres:
#   POSTGRES_URL or PRISMA_DATABASE_URL → DATABASE_URL (app runtime + migrations)
#   DIRECT_URL — optional; only needed if you have a separate non-pooled URL
DATABASE_URL=
DIRECT_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Seed script — first admin user (prisma db seed)
SEED_ADMIN_EMAIL=admin@admin.com    
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=admin

# Airtable import (Phase 6 cutover — remove after migration)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Email
RESEND_API_KEY=
NEXT_PUBLIC_PORTAL_URL=https://portal.utahdigs.com

# Vercel may also inject these (map POSTGRES_URL → DATABASE_URL in .env.local):
# POSTGRES_URL=
# PRISMA_DATABASE_URL=
