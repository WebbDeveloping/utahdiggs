# Copy from Vercel dashboard after provisioning Prisma Postgres:
#   POSTGRES_URL or PRISMA_DATABASE_URL → DATABASE_URL (app runtime + migrations)
#   DIRECT_URL — optional; only needed if you have a separate non-pooled URL
# If the URL includes sslmode=require, change it to sslmode=verify-full (or the app normalizes it at runtime).
DATABASE_URL=
DIRECT_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Seed script — first admin user (prisma db seed)
SEED_ADMIN_EMAIL=admin@admin.com    
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=admin

# Airtable sync (duplicate base — weekly cron + manual npm run sync:airtable)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Vercel Cron auth — generate with: openssl rand -base64 32
CRON_SECRET=

# Email (Resend — verify glidere.com and add DNS records in GoDaddy)
RESEND_API_KEY=
# Who receives MLS intake-submitted emails (VA inbox). Falls back to AGENT_NOTIFICATION_EMAIL.
MLS_VA_NOTIFICATION_EMAIL=
AGENT_NOTIFICATION_EMAIL=blair@glidere.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel may also inject these (map POSTGRES_URL → DATABASE_URL in .env.local):
# POSTGRES_URL=
# PRISMA_DATABASE_URL=

# Vercel Blob — pulled via `vercel env pull` after creating stores in the Vercel dashboard.
# Public store (photos): Vercel defaults to BLOB_STORE_ID + BLOB_READ_WRITE_TOKEN
# Private store (docs):  Vercel adds BLOB_PRIVATE_STORE_ID — rename the private token to
#   BLOB_PRIVATE_READ_WRITE_TOKEN (Vercel may label both tokens BLOB_READ_WRITE_TOKEN;
#   only one key can exist per file — the private value must use the BLOB_PRIVATE_ name)
# BLOB_STORE_ID=
# BLOB_READ_WRITE_TOKEN=
# BLOB_PRIVATE_STORE_ID=
# BLOB_PRIVATE_READ_WRITE_TOKEN=